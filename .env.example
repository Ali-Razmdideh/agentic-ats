ANTHROPIC_API_KEY=your_api_key_here

# Postgres (asyncpg DSN)
ATS_PG_DSN=postgresql+asyncpg://ats:ats@localhost:5432/ats
ATS_PG_POOL_SIZE=10
ATS_PG_POOL_MAX_OVER=20

# MinIO / S3-compatible blob store
ATS_MINIO_ENDPOINT=http://localhost:9000
ATS_MINIO_ACCESS_KEY=minioadmin
ATS_MINIO_SECRET_KEY=minioadmin
ATS_MINIO_BUCKET=ats-artifacts
ATS_MINIO_REGION=us-east-1

ATS_INBOX_DIR=./inbox
ATS_DEFAULT_ORG_SLUG=system

# HMAC secret for the audit_log chain. Hex-encoded 32 bytes. The worker
# AND the dashboard MUST share this value; otherwise rows written from
# either side will not verify on the other. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ATS_AUDIT_HMAC_KEY=
